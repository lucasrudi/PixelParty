{
  "name": "pixelparty",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:functional": "vitest run src/components/*.test.tsx src/lib/*.test.ts",
    "test:e2e": "vitest run src/test/e2e/*.test.ts",
    "test:precommit": "npm run test:functional && npm run test:e2e",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.1",
    "next": "16.2.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
